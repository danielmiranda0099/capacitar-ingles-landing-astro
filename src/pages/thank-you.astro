---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <div class="container">
      <div class="content">
        <div class="video-wrapper">
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/aaLgv4MBRno?si=XNhmoco7zB6IYW-D"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>

        <h1 class="title">Gracias por tu registro</h1>
        <p class="subtitle">Tu confianza significa mucho para nosotros</p>

        <a
          href="https://www.instagram.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="instagram-btn"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              fill="currentColor"></path>
          </svg>
          Síguenos en Instagram
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .title {
    font-size: 2.45rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-blue-700, #0f1734);
    text-align: center;
    margin: 0;
  }

  .subtitle {
    font-size: 1.25rem;
    line-height: 1.4;
    color: var(--color-blue-600, #5f6a8d);
    text-align: center;
    margin: 0;
    font-weight: 400;
    margin-top: -0.3rem;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .instagram-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.7rem;
    font-size: var(--size-1, 1rem);
    font-weight: 700;
    color: white;
    background: linear-gradient(
      45deg,
      #f09433 0%,
      #e6683c 25%,
      #dc2743 50%,
      #cc2366 75%,
      #bc1888 100%
    );
    border-radius: 22px;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 4px 15px rgba(188, 24, 136, 0.3);
    margin-bottom: 2rem;
  }

  .instagram-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(188, 24, 136, 0.4);
  }

  .instagram-btn:active {
    transform: translateY(0);
  }

  @media screen and (max-width: 768px) {
    .title {
      font-size: 2rem;
    }

    .subtitle {
      font-size: 1.125rem;
    }

    .instagram-btn {
      padding: 0.7rem 1rem;
      font-size: 0.95rem;
    }
  }

  @media screen and (max-width: 480px) {
    main {
      padding: var(--size-1x, 1.25rem) var(--size-px7, 0.75rem);
    }

    .title {
      font-size: 1.75rem;
    }

    .subtitle {
      font-size: 1rem;
    }

    .content {
      gap: var(--size-1x2, 1.5rem);
    }
  }
</style>
