---
interface Props {
  columnMode?: "one-col" | "two-col";
  isBoxShadow?: boolean;
  prefix?: string;
}

const { columnMode = "two-col", isBoxShadow = true, prefix = "" } = Astro.props;
---

<form
  class={`form-register ${columnMode} ${isBoxShadow ? "box-shadow-form" : ""}`}
  aria-label="Formulario de Registro"
  id={`form-${prefix}`}
>
  <div class="inputs-grid">
    <div class="input-group">
      <label for={`${prefix}-name`}>Nombre completo:</label>
      <input
        type="text"
        id={`${prefix}-name`}
        name="name"
        placeholder="Ingresa tu nombre completo"
        required
        minlength="3"
      />
    </div>

    <div class="input-group">
      <label for={`${prefix}-email`}>Correo:</label>
      <input
        type="email"
        id={`${prefix}-email`}
        name="email"
        placeholder="tu-correo@gmail.com"
        required
      />
    </div>

    <div class="input-group">
      <label for={`${prefix}-age`}>Edad:</label>
      <input
        type="number"
        id={`${prefix}-age`}
        name="age"
        placeholder="Ingresa tu edad"
        required
        min="1"
        max="120"
      />
    </div>

    <div class="input-group">
      <label for={`${prefix}-phone`}>Teléfono:</label>
      <input
        type="tel"
        id={`${prefix}-phone`}
        name="phone"
        placeholder="123-4567"
        required
        minlength="7"
      />
    </div>
  </div>

  <!-- Mensaje de error -->
  <div class="message error-message" id={`error-${prefix}`} style="display: none;">
    <p></p>
  </div>

  <!-- Mensaje de éxito -->
  <div class="message success-message" id={`success-${prefix}`} style="display: none;">
    <p>¡Registro exitoso! Redirigiendo...</p>
  </div>

  <div class="button-container">
    <button type="submit" class="cs-btn button-free-trial light" id={`btn-${prefix}`}>
      Prueba Gratuita
    </button>
  </div>
</form>

<style>
  .form-register {
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 0 auto;
    padding: 1rem;
    background-color: white;
    border-radius: 22px;
  }
  .box-shadow-form {
    box-shadow:
      0 0 5px 0 rgba(78, 105, 105, 0.1),
      0 2px 7px 0 rgba(78, 105, 105, 0.1),
      0 4px 4px -2px rgba(78, 105, 105, 0.1);
  }

  /* Grid adaptable según columnMode */
  .inputs-grid {
    display: grid;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  /* 1 columna */
  .form-register.one-col .inputs-grid {
    grid-template-columns: 1fr;
  }

  /* 2 columnas (default) */
  .form-register.two-col .inputs-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  /* Grupo de input individual */
  .input-group {
    display: inline-flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-group label {
    font-weight: 600;
    color: var(--bg-blue-700, #1e3a8a);
    letter-spacing: -0.01em;
    font-size: 0.95rem;
  }

  .input-group input {
    width: 100%;
    padding: 0.6rem 0.8rem;
    border: 2px solid #e2e8f0;
    border-radius: 14px;
    font-size: 0.8rem;
    font-family: "Inter", sans-serif;
    background: #f8fafc;
    color: #0f2027;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .input-group input:focus {
    outline: none;
    border-color: #62d1f9;
    background: white;
    box-shadow: 0 0 0 3px rgba(98, 209, 249, 0.1);
  }

  .input-group input::placeholder {
    color: #94a3b8;
  }

  .input-group input.error {
    border-color: #ef4444;
    background: #fef2f2;
  }

  /* Mensajes */
  .message {
    padding: 0.75rem 1rem;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    position: relative;
    z-index: 1;
  }

  .error-message {
    background: #fef2f2;
    color: #dc2626;
    border: 2px solid #fecaca;
  }

  .success-message {
    background: #f0fdf4;
    color: #16a34a;
    border: 2px solid #bbf7d0;
  }

  /* Botón */
  .button-container {
    position: relative;
    z-index: 1;
    padding: 0;
  }

  .cs-btn {
    position: relative;
    transition: all 0.3s ease;
  }

  .cs-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Gradientes de fondo - z-index negativo para que no interfieran */
  .form-register::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 22px;
    background: linear-gradient(45deg, #77dbff, #ffffff, #ffffff, #88ffa4);
    filter: blur(22px);
    opacity: 0.4;
    z-index: -2;
  }

  .form-register::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 22px;
    border: 2.5px solid transparent;
    background: linear-gradient(
        45deg,
        #62d1f9,
        #ffffff,
        #ffffff,
        #ffffff,
        #ffffff,
        #82fd9f
      )
      border-box;
    -webkit-mask:
      linear-gradient(#fff 0 0) padding-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    z-index: -1;
    pointer-events: none;
  }

  /* Responsividad */
  @media (max-width: 640px) {
    .form-register.two-col .inputs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ prefix }}>
  /* ================================
     CONFIGURACIÓN DE WORDPRESS
  ================================= */
  const SITE_URL = 'https://www.inglescapacitar.com';
  const WP_USER = 'fredyabadia';
  const WP_APP_PASSWORD = 'J29w g1dY LX21 7z3S RUJZ 6uIx';
  const ENDPOINT = `${SITE_URL}/wp-json/wp/v2/regis_form_marketing`;
  const REDIRECT_URL = '/thank-you'; // URL a donde redirigir después del éxito

  /* ================================
     FUNCIONES DE VALIDACIÓN
  ================================= */
  function validarEmail(email) {
    const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return regex.test(email);
  }

  function validarTelefono(telefono) {
    const regex = /^[\d\s\-\+\(\)]+$/;
    return regex.test(telefono) && telefono.replace(/\D/g, '').length >= 7;
  }

  function validarEdad(edad) {
    const edadNum = parseInt(edad, 10);
    return !isNaN(edadNum) && edadNum > 0 && edadNum <= 120;
  }

  function validarNombre(nombre) {
    return nombre.trim().length >= 3;
  }

  function mostrarError(mensaje) {
    const errorDiv = document.getElementById(`error-${prefix}`);
    const successDiv = document.getElementById(`success-${prefix}`);
    
    successDiv.style.display = 'none';
    errorDiv.style.display = 'block';
    errorDiv.querySelector('p').textContent = mensaje;
    
    // Scroll al mensaje de error
    errorDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function mostrarExito() {
    const errorDiv = document.getElementById(`error-${prefix}`);
    const successDiv = document.getElementById(`success-${prefix}`);
    
    errorDiv.style.display = 'none';
    successDiv.style.display = 'block';
    
    // Scroll al mensaje de éxito
    successDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function ocultarMensajes() {
    document.getElementById(`error-${prefix}`).style.display = 'none';
    document.getElementById(`success-${prefix}`).style.display = 'none';
  }

  /* ================================
     FUNCIÓN PARA OBTENER LA CIUDAD
  ================================= */
  async function obtenerCiudad() {
    try {
      // Primero obtener la IP del usuario
      const ipResponse = await fetch('https://api.ipify.org?format=json');
      const ipData = await ipResponse.json();
      const userIP = ipData.ip;
      
      // Luego obtener la ciudad usando ip.gude
      const locationResponse = await fetch(`https://ip.guide/${userIP}`);
      const locationData = await locationResponse.json();
      console.log("api location data:", locationData);
      return locationData.location.city || 'Desconocida';
    } catch (error) {
      console.error('Error al obtener la ciudad:', error);
      return 'Desconocida';
    }
  }

  /* ================================
     MANEJO DEL FORMULARIO
  ================================= */
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById(`form-${prefix}`);
    const submitBtn = document.getElementById(`btn-${prefix}`);
    
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      ocultarMensajes();

      // Obtener valores del formulario
      const nombreCompleto = document.getElementById(`${prefix}-name`).value.trim();
      const correo = document.getElementById(`${prefix}-email`).value.trim();
      const edad = document.getElementById(`${prefix}-age`).value;
      const telefono = document.getElementById(`${prefix}-phone`).value.trim();

      // Validaciones
      if (!validarNombre(nombreCompleto)) {
        mostrarError('Por favor, ingresa un nombre completo válido (mínimo 3 caracteres).');
        return;
      }

      if (!validarEmail(correo)) {
        mostrarError('Por favor, ingresa un correo electrónico válido.');
        return;
      }

      if (!validarEdad(edad)) {
        mostrarError('Por favor, ingresa una edad válida (entre 1 y 120 años).');
        return;
      }

      if (!validarTelefono(telefono)) {
        mostrarError('Por favor, ingresa un número de teléfono válido.');
        return;
      }

      // Deshabilitar botón durante el envío
      submitBtn.disabled = true;
      const textoOriginal = submitBtn.textContent;
      submitBtn.textContent = 'Enviando...';

      try {
        // Obtener la ciudad del usuario
        const ciudad = await obtenerCiudad();
        
        // Codificar credenciales
        const credentials = btoa(`${WP_USER}:${WP_APP_PASSWORD}`);

        // Enviar datos a WordPress
        const response = await fetch(ENDPOINT, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Basic ${credentials}`
          },
          body: JSON.stringify({
            title: nombreCompleto,
            status: 'publish',
            acf: {
              "nombre-completo": nombreCompleto,
              email: correo,
              edad: parseInt(edad, 10),
              telefono: telefono,
              ciudad: ciudad
            }
          })
        });

        const contentType = response.headers.get('content-type');
        let data;

        if (contentType && contentType.includes('application/json')) {
          data = await response.json();
        } else {
          const text = await response.text();
          throw new Error(`Respuesta inesperada del servidor: ${text.substring(0, 100)}`);
        }

        if (!response.ok) {
          throw new Error(data.message || `Error del servidor: ${response.status}`);
        }

        // Éxito: mostrar mensaje y redirigir
        mostrarExito();
        form.reset();
        
        // Redirigir después de 3 segundos
        setTimeout(() => {
          window.location.href = REDIRECT_URL;
        }, 3000);

      } catch (error) {
        console.error('Error al enviar el formulario:', error);
        mostrarError(`Error al enviar el formulario: ${error.message}`);
        
        // Rehabilitar botón
        submitBtn.disabled = false;
        submitBtn.textContent = textoOriginal;
      }
    });
  });
</script>