---
import Divider from "./Divider.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="container-feature-item">
  <div class="container-icon-feature-item">
    <slot />
  </div>
  <div class="text-feature-item">
    <h3 class="title-feature-item cs-text-lg">
      {title}
    </h3>
  </div>
  <Divider width="45px" height="4px" />
</div>

<style>
  .container-feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 0rem 1rem;
    border-radius: 1rem;
    width: 22ch; /* Ajusta según necesites */
    --tw-shadow: 0 0 5px 0 rgba(78, 105, 105, 0.1),
      0 2px 7px 0 rgba(78, 105, 105, 0.1),
      0 4px 4px -2px rgba(78, 105, 105, 0.1);
    box-shadow: var(--tw-shadow);
    height: 10rem;
  }

  .text-feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
  }

  .title-feature-item {
    font-weight: bold;
    text-align: center;

    /* Esto permite que el texto se divida en varias líneas */
    word-wrap: break-word;
    overflow-wrap: break-word;

    /* Esto añade el guion (-) cuando una palabra es muy larga */
    hyphens: auto;
    -webkit-hyphens: auto;
    -ms-hyphens: auto;
    line-height: 0.98;
  }

  .container-icon-feature-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem;
    background: linear-gradient(
      135deg,
      var(--bg-blue-400),
      var(--bg-green-400)
    );
    border-radius: 50%;
    --tw-shadow: 0 0 5px 0 rgba(78, 105, 105, 0.5),
      0 2px 7px 0 rgba(78, 105, 105, 0.5),
      0 4px 4px -2px rgba(78, 105, 105, 0.5);
    box-shadow: var(--tw-shadow);
  }

  @media screen and (width <= 800px) {
    .container-feature-item {
      height: 8rem;
      gap: 0.5rem;
      padding: 0rem 0.1rem;
    }

    .title-feature-item {
      font-size: 1rem;
    }
  }
</style>
