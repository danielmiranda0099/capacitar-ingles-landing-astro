---
import Divider from "@/components/Divider.astro";
import StarIcon from "@/components/icons/StarIcon.astro";
---

<section class="section-container testimonies-section">
  <div class="testimonies-header">
    <h2 class="cs-text-3xl">Testimonios</h2>
    <Divider width="60%" />
  </div>
  <div class="swiper-container">
    <!-- Contenedor principal de Swiper -->
    <div class="swiper testimonies-slider">
      <!-- Wrapper adicional requerido -->
      <div class="swiper-wrapper">
        <!-- Los slides -->
        <div class="swiper-slide">
          <div class="container-testimony">
            <video controls>
              <source
                src="/videos/vertical-01-nino-optimizado.mp4"
                type="video/mp4"
              />
            </video>
            <div class="text-content-testimony">
              <h2 class="cs-text-xl">
                Gracias a CAPACITAR, ahora hablo inglés con más confianza en mi
                trabajo y en viajes. Las clases son muy prácticas.
              </h2>

              <Divider width="45px" />

              <div>
                <StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="swiper-slide">
          <div class="container-testimony">
            <video controls>
              <source
                src="/videos/vertical-02-mujer-optimizado.mp4"
                type="video/mp4"
              />
            </video>
            <div class="text-content-testimony">
              <h2 class="cs-text-xl">
                Las clases en vivo con docentes nativos hicieron la diferencia.
                Ahora entiendo y hablo inglés con mucha más naturalidad.
              </h2>

              <Divider width="45px" />

              <div>
                <StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="swiper-slide">
          <div class="container-testimony">
            <video controls>
              <source
                src="/videos/vertical-03-escalera-optimizado.mp4"
                type="video/mp4"
              />
            </video>
            <div class="text-content-testimony">
              <h2 class="cs-text-xl">
                Mi hijo disfruta cada clase y ha aprendido inglés de forma
                divertida. Su pronunciación y confianza han mejorado muchísimo.
              </h2>

              <Divider width="45px" />

              <div>
                <StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                /><StarIcon
                  width="1.8rem"
                  height="1.8rem"
                  stroke="#ffd700"
                  fill="#ffd700"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Botones de navegación -->
      <div class="swiper-pagination swiper-pagination-testimonies"></div>
    </div>
    <div class="swiper-button-prev swiper-button-prev-testimonies"></div>
    <div class="swiper-button-next swiper-button-next-testimonies"></div>
  </div>
</section>

<style>
  .testimonies-section {
    width: 95%;
    overflow: hidden;
    flex-direction: column;
    /* gap: 2.5rem; */

    .testimonies-header {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      width: fit-content;
      font-weight: 900;
      margin: 0 auto;
    }
  }
  .swiper-container {
    width: 50rem;
    margin: 0 auto;
  }
  .swiper {
    /* background-color: red; */
  }
  .swiper-wrapper {
    display: flex;
  }
  .swiper-slide {
    overflow: visible;
    padding: 1rem;

    .container-testimony {
      padding: 1.5rem;
      background-color: rgb(249, 254, 255);
      margin: 0 auto;
      width: 90%;
      display: flex;
      gap: 1rem;
      border-radius: 22px;
      --tw-shadow:
        0 0 5px 0 rgba(78, 105, 105, 0.1), 0 2px 7px 0 rgba(78, 105, 105, 0.1),
        0 4px 4px -2px rgba(78, 105, 105, 0.1);
      box-shadow: var(--tw-shadow);
      .text-content-testimony {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 0.8rem;
        h2 {
          font-weight: 600;
          text-align: center;
        }
      }
    }
  }
  .swiper-slide video {
    height: 20rem;
    object-fit: cover;
    border-radius: 22px;
    aspect-ratio: 9 / 16 !important;
  }

  @media screen and (width <= 800px) {
    .swiper-container {
      width: 100%;
    }
    .swiper-slide {
      .container-testimony {
        padding: 0.8rem;
        gap: 0.5rem;
        .text-content-testimony {
          h2 {
            font-size: 1rem;
            font-weight: 600;
            text-align: center;
          }
        }
      }
    }
    .swiper-slide video {
      height: 16rem;
    }
  }
</style>

<script>
  // Core de Swiper y estilos
  import Swiper from "swiper";
  import "swiper/css";
  // Módulo Navigation de Swiper y estilos
  import {
    Autoplay,
    Navigation,
    Pagination,
    EffectCoverflow,
  } from "swiper/modules";
  import "swiper/css/navigation";
  import "swiper/css/effect-coverflow";

  // Configurar Swiper
  const swiper_testimonies = new Swiper(".testimonies-slider", {
    modules: [Autoplay, Navigation, Pagination, EffectCoverflow],
    effect: "coverflow",
    loop: true, // definir si los slides estarán en bucle
    centeredSlides: true,
    slidesPerView: 1, // agregar número de slides para la pantalla
    spaceBetween: 40, // separación entre slides en px
    coverflowEffect: {
      rotate: 0,
      stretch: 0,
      depth: 100,
      modifier: 1,
      slideShadows: true,
    },
    navigation: {
      // definir botones next y prev para el módulo Navigation
      prevEl: ".swiper-button-prev-testimonies",
      nextEl: ".swiper-button-next-testimonies",
    },
    pagination: {
      el: ".swiper-pagination-testimonies",
      clickable: true,
    },
    autoplay: {
      delay: 3000,
      disableOnInteraction: true,
      pauseOnMouseEnter: true,
    },
  });
</script>
