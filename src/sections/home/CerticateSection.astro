---
import DecorativeBubble from "@/components/DecorativeBubble.astro";
import Divider from "@/components/Divider.astro";
import CheckIcon from "@/components/icons/CheckIcon.astro";
---

<section class="section-container certificate-section">
  <DecorativeBubble />
  <div class="certificate-container">
    <div class="certificate-image-container">
      <img
        src="whyChooseUs.png"
        alt="Certificado de Academia de Inglés"
        class="certificate-img"
      />
    </div>

    <div class="certificate-header-container">
      <div class="title-container">
        <h2 class="certificate-title cs-text-3xl">
          Un método efectivo que sí funciona, Aprender inglés nunca había sido
          tan divertido
        </h2>
        <Divider width="160px" />
      </div>

      <p class="certificate-description">
        Nuestro programa está diseñado para prepararte y brindarte las
        herramientas necesarias para destacar en el ámbito profesional y
        académico.
      </p>
    </div>

    <div class="certificate-benefits-container">
      <ul class="certificate-benefits">
        <li class="benefit-item">
          <div class="container-check-icon">
            <CheckIcon class="check-icon" />
          </div>
          <span
            >Programa estructurado para todas las edades, desde nivel inicial
            hasta avanzado.</span
          >
        </li>

        <li class="benefit-item">
          <div class="container-check-icon">
            <CheckIcon class="check-icon" />
          </div>
          <span>Mejora tus oportunidades laborales</span>
        </li>

        <li class="benefit-item">
          <div class="container-check-icon">
            <CheckIcon class="check-icon" />
          </div>
          <span
            >Clases activas y comunicativas para aprender hablando, no
            memorizando.</span
          >
        </li>

        <li class="benefit-item">
          <div class="container-check-icon">
            <CheckIcon class="check-icon" />
          </div>
          <span>Método efectivo</span>
        </li>

        <li class="benefit-item">
          <div class="container-check-icon">
            <CheckIcon class="check-icon" />
          </div>
          <span>Soporte y seguimiento personalizado</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .certificate-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(25deg, #076460, 40%, var(--bg-blue-700));
    width: 100%;
    padding: 5rem 1rem;

    > .certificate-container {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, auto);
      gap: 1rem;
      align-items: center;
      color: white;

      > .certificate-image-container {
        grid-row: span 2 / span 2;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;

        > .certificate-img {
          width: 67%;
          height: auto;
          /* border: 2px solid var(--bg-blue-700); */
          border-radius: 8px;
          /* box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1); */
          /* -webkit-mask-image: linear-gradient(black, transparent);*/
          mask-image: linear-gradient(black, transparent);

          /* -webkit-mask-image: radial-gradient(circle, black 50%, rgba(0, 0, 0, 0.5) 50%); */
          mask-image: radial-gradient(ellipse, black 50%, transparent 80%);
          /* linear-gradient(black 60%, transparent); */
        }
      }

      > .certificate-header-container {
        position: relative;
        > .title-container {
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: flex-start;
          gap: 0.4rem;
          margin-bottom: 0.8rem;
          .certificate-title {
            font-weight: 900;
            color: white;
          }
        }

        > .certificate-description {
          font-size: 1.125rem;
        }
      }

      > .certificate-benefits-container {
        position: relative;
        grid-column-start: 2;
        .certificate-benefits {
          list-style: none;
          padding: 0;
          margin: 0;

          .benefit-item {
            display: flex;
            align-items: center;
            margin-bottom: 1.25rem;
            font-size: 1rem;
            font-weight: 500;
          }

          .benefit-item:last-child {
            margin-bottom: 0;
          }
        }
      }
    }
  }

  @media (width <= 1100px) {
    .certificate-section {
      /* padding: 2rem 1rem; */
      > .certificate-container {
        > .certificate-image-container {
          grid-column-start: 2;
          grid-row-start: 2;
          > .certificate-img {
            max-width: 400px;
          }
        }

        > .certificate-header-container {
          grid-column: span 2 / span 2;
          grid-column-start: 1;
          grid-row-start: 1;
          > .title-container {
            .certificate-title {
              font-size: 2rem;
            }
          }

          > .certificate-description {
            font-size: 1rem;
          }
        }

        > .certificate-benefits-container {
          grid-column-start: 1;
          grid-row-start: 2;
          .certificate-benefits {
            .benefit-item {
            }

            .benefit-item:last-child {
            }
            .container-check-icon {
            }
            .check-icon {
            }
          }
        }
      }
    }
  }

  @media (width <= 680px) {
    .certificate-section {
      > .certificate-container {
        > .certificate-image-container {
          > .certificate-img {
            width: 90%;
          }
        }

        > .certificate-header-container {
          > .title-container {
            .certificate-title {
            }
          }

          > .certificate-description {
          }
        }

        > .certificate-benefits-container {
          margin-top: 0;
          .certificate-benefits {
            .benefit-item {
              font-size: 0.8rem;
              gap: 0.2rem;
            }

            .benefit-item:last-child {
            }
            .container-check-icon {
              padding: 0.1rem;
            }
            .check-icon {
              width: 12px;
              height: 12px;
            }
          }
        }
      }
    }
  }
</style>
